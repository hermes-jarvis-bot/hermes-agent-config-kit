   "expect": "output",
   "stdout_contains": ["/observability-monitoring", "Evidence-backed monitoring"],
   "stdout_not_contains": []},
  {"id": "skills and hooks audit routes to harness audit", "hook": "keyword-skill-router.py",
   "stdin": {"user_prompt": "Проверь все скиллы и хуки и автоматическое подтягивание по смыслу."},
   "expect": "output",
   "stdout_contains": ["/harness-audit"],
   "stdout_not_contains": []},

  {"id": "git status allowed", "hook": "git-destructive-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "git status -sb"}}, "expect": "allow"},
  {"id": "force-with-lease allowed", "hook": "git-destructive-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "git push --force-with-lease origin main"}}, "expect": "allow"},
  {"id": "push --force blocked", "hook": "git-destructive-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "git push --force origin main"}}, "expect": "block",
   "reason_contains": "force-with-lease"},
  {"id": "reset --hard blocked", "hook": "git-destructive-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "git reset --hard HEAD~3"}}, "expect": "block"},
  {"id": "clean -fdx blocked", "hook": "git-destructive-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "git clean -fdx"}}, "expect": "block"},

  {"id": "trivial substitution allowed", "hook": "command-injection-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "echo \"now: $(date)\""}}, "expect": "allow"},
  {"id": "destructive substitution blocked", "hook": "command-injection-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "gh issue create --body \"plan: $(dropdb prod)\""}}, "expect": "block"},
  {"id": "no substitution allowed", "hook": "command-injection-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "echo 'literal $(dropdb prod) in single quotes'"}}, "expect": "allow"},

  {"id": "killall node blocked", "hook": "self-harm-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "killall node"}}, "expect": "block"},
  {"id": "reboot blocked", "hook": "self-harm-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "sudo reboot"}}, "expect": "block"},
  {"id": "systemctl status allowed", "hook": "self-harm-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "systemctl status sshd"}}, "expect": "allow"},
  {"id": "bare reboot blocked (regression 2026-06-10)", "hook": "self-harm-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "reboot"}}, "expect": "block"},
  {"id": "reboot as grep argument allowed", "hook": "self-harm-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "grep reboot /var/log/syslog | tail -5"}}, "expect": "allow"},

  {"id": "adding pytest skip in tests blocked", "hook": "test-muting-guard.py",
   "stdin": {"tool_name": "Edit", "tool_input": {"file_path": "tests/test_foo.py",
     "old_string": "def test_a():\n    assert f()", "new_string": "@pytest.mark.skip\ndef test_a():\n    assert f()"}},
   "expect": "block"},
  {"id": "skip outside test dirs allowed", "hook": "test-muting-guard.py",
   "stdin": {"tool_name": "Edit", "tool_input": {"file_path": "src/runner.py",
     "old_string": "x = 1", "new_string": "x = 1  # pytest.skip( reference in docs"}},
   "expect": "allow"},
  {"id": "normal test edit allowed", "hook": "test-muting-guard.py",
   "stdin": {"tool_name": "Edit", "tool_input": {"file_path": "tests/test_foo.py",
     "old_string": "assert f() == 1", "new_string": "assert f() == 2"}},
   "expect": "allow"},

  {"id": "cyrillic slash-lists not flagged, real missing path flagged",
   "hook": "session-drift-validator.py",
   "stdin": {},
   "files": {
     "CLAUDE.md": "# t\n",
     ".claude/rules/sample.md": "Решение опирается на код/probe/доки/чек-лист и GPU/port/container.\nСм. ./missing/definitely-not-here.md и code.claude.com/docs/en/code-review.\n"
   },
   "expect": "output",
   "stdout_contains": ["./missing/definitely-not-here.md"],
   "stdout_not_contains": ["probe", "GPU/port/container", "code.claude.com"]},

  {"id": "latest handoff per project, both projects visible",
   "hook": "session-handoff-check.py",
   "stdin": {},
   "files": {
     ".claude/handoffs/proj-a/2099-01-01_10-00_aaaaaaaa.md": "# Handoff A\nGoal: alpha work\n",
     ".claude/handoffs/proj-b/2099-01-02_09-00_bbbbbbbb.md": "# Handoff B\nGoal: beta work\n",
     ".claude/handoffs/INDEX.md": "# Handoffs Index\n"
   },
   "expect": "output",
   "stdout_contains": ["[proj-a]", "[proj-b]", "Goal: beta work"],
   "stdout_not_contains": []}
