   "stdout_contains": ["Enter plan mode (built-in)", "Write .claude/handoffs"],
   "stdout_not_contains": ["Use skill plan", "Use skill handoff"]},
  {"id": "monitoring routes to observability skill", "hook": "keyword-skill-router.py",
