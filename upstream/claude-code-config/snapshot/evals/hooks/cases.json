[
  {"id": "plain ls allowed", "hook": "destructive-command-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "ls -la"}}, "expect": "allow"},
  {"id": "rm -rf in /tmp allowed", "hook": "destructive-command-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "rm -rf /tmp/scratch-dir"}}, "expect": "allow"},
  {"id": "rm -rf root blocked", "hook": "destructive-command-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "rm -rf /"}}, "expect": "block"},
  {"id": "DROP TABLE blocked", "hook": "destructive-command-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "psql -c 'DROP TABLE users;'"}}, "expect": "block"},
  {"id": "docker prune volumes blocked", "hook": "destructive-command-guard.py",
   "stdin": {"tool_name": "Bash", "tool_input": {"command": "docker system prune -a --volumes"}}, "expect": "block"},
  {"id": "bypass marker allows", "hook": "destructive-command-guard.py",
