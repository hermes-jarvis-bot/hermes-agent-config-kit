  {"id": "retouch security routes to required security skill", "hook": "keyword-skill-router.py",
   "stdin": {"user_prompt": "Проверь безопасность retouch Photoshop plugin перед релизом: pentest, tamper, license bypass, model theft."},
   "expect": "output",
